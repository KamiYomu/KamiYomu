@using KamiYomu.CrawlerAgents.Core.Inputs
@using KamiYomu.Web.Areas.Settings.Pages.CrawlerAgents
@using KamiYomu.Web.Areas.Settings.Pages.Shared
@model CrawlerInputsViewModel

@foreach (var inputField in Model.CrawlerInputs.OrderBy(p => p.Order))
{
    @if (inputField is CrawlerTextAttribute crawlerText)
    {
        var formValue = Model.AgentMetadata.TryGetValue(crawlerText.Name, out var value)
            ? value?.ToString() ?? string.Empty
            : crawlerText.DefaultValue;

        @ViewData.ModelState.TryGetValue($"AgentMetadata[{crawlerText.Name}]", out var entry)


        <vc:crawler-text crawler-text-attribute="@crawlerText"
                         field-name="Input.CrawlerInputsViewModel.AgentMetadata[@crawlerText.Name]"
                         field-value="@formValue"
                         model-state-entry="entry" />
    }
    else if (inputField is CrawlerPasswordAttribute crawlerPassword)
    {
        var formValue = Model.AgentMetadata.TryGetValue(crawlerPassword.Name, out var value)
        ? value?.ToString() ?? string.Empty
        : crawlerPassword.DefaultValue;

        @ViewData.ModelState.TryGetValue($"AgentMetadata[{crawlerPassword.Name}]", out var entry)


        <vc:crawler-password crawler-password-attribute="@crawlerPassword"
                             field-name="Input.CrawlerInputsViewModel.AgentMetadata[@crawlerPassword.Name]"
                             field-value="@formValue"
                             model-state-entry="entry" />
    }
    else if (inputField is CrawlerSelectAttribute crawlerSelect)
    {

        var selected = Model.AgentMetadata.TryGetValue(crawlerSelect.Name, out var value)
        && value is string stringValue
        && !string.IsNullOrWhiteSpace(stringValue)
        ? stringValue
        : crawlerSelect.DefaultValue;

        @ViewData.ModelState.TryGetValue($"AgentMetadata[{crawlerSelect.Name}]", out var entry)

        var fieldName = $"Input.CrawlerInputsViewModel.AgentMetadata[{crawlerSelect.Name}]";

        <vc:crawler-select crawler-select-attribute="@crawlerSelect"
                           field-name="@fieldName"
                           field-value="@selected"
                           model-state-entry="entry" />

    }
    else if (inputField is CrawlerCheckBoxAttribute crawlerCheckbox)
    {
        @ViewData.ModelState.TryGetValue($"AgentMetadata[{crawlerCheckbox.Name}]", out var entry)

        <vc:crawler-check-box crawler-check-box-attribute="@crawlerCheckbox"
                              selected-data="Model.AgentMetadata"
                              model-state-entry="entry" />
    }
}
